# LLM Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# NVIDIA NIM (OpenAI-compatible) — use when OpenAI quota is exceeded or prefer this provider
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=google/gemma-4-31b-it
# Optional (match NVIDIA chat/completions body)
NVIDIA_MAX_TOKENS=16384
NVIDIA_TEMPERATURE=0
NVIDIA_TOP_P=0.95
NVIDIA_ENABLE_THINKING=true

# Default LLM in Streamlit sidebar (openai | nvidia | anthropic | gemini)
LLM_PROVIDER=nvidia
LLM_MODEL=google/gemma-4-31b-it

# App Runtime Settings
RATE_LIMIT_PER_MIN=30
VALIDATION_JOBS_DIR=/tmp/staging/jobs

# Optional UI -> API override (if needed outside docker compose)
API_BASE=http://localhost:8000

# Firebase (Realtime DB) for storing completed validation reports
FIREBASE_DATABASE_URL=https://agent-validation-83fe8-default-rtdb.firebaseio.com
# Optional if DB rules require auth token:
FIREBASE_DB_SECRET=
